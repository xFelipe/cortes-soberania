# =====================================================
# Anthropic Claude API
# Obter em: https://console.anthropic.com/settings/keys
# =====================================================
ANTHROPIC_API_KEY=sk-ant-api03-...

# Modelos a usar (não precisa mexer)
ANTHROPIC_MODEL_TRIAGE=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_DEEP=claude-sonnet-4-6

# =====================================================
# YouTube Data API v3 (para discover e leitura)
# Obter em: https://console.cloud.google.com/apis/credentials
#   1. Criar projeto
#   2. Ativar "YouTube Data API v3"
#   3. Criar credencial "API Key" (sem restrições no início)
# =====================================================
YOUTUBE_API_KEY=AIzaSy...

# =====================================================
# YouTube OAuth (para upload na conta do canal)
# Obter em: https://console.cloud.google.com/apis/credentials
#   1. Criar credencial "OAuth client ID"
#   2. Application type: Desktop app
#   3. Baixar JSON e salvar no caminho abaixo
#   4. Adicionar sua conta como "test user" em OAuth consent screen
# =====================================================
YOUTUBE_OAUTH_CLIENT_SECRETS_PATH=/home/youruser/.config/canal-soberania/client_secrets.json
YOUTUBE_OAUTH_TOKEN_PATH=/home/youruser/.config/canal-soberania/youtube_token.json

# =====================================================
# Whisper (faster-whisper)
# =====================================================
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu          # ou "cuda" se tiver GPU
WHISPER_COMPUTE_TYPE=int8   # cpu: int8; cuda: float16

# =====================================================
# Diretórios (relativos ao repo, normalmente não mexer)
# =====================================================
DATA_DIR=./data

# =====================================================
# Telegram alerts (opcional, Fase 3+)
# =====================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =====================================================
# Comportamento
# =====================================================
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
DRY_RUN=false               # true = não executa side effects (download, upload)

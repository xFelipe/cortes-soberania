{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "path:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "$HOME/.config/canal-soberania/.api_token" }]
    },
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
